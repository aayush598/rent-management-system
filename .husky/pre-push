#!/usr/bin/env sh
if ! docker info >/dev/null 2>&1; then
  echo "⚠ Docker daemon not running. Skipping Docker validation."
  echo "  Start it with: sudo systemctl start docker"
  echo "  Enable at boot: sudo systemctl enable --now docker"
  exit 0
fi

[ ! -f .env ] && echo "✗ .env file not found" && exit 1

. ./.env

echo "Building Docker image to validate..."

docker build -t rent-management-system:latest . \
  --build-arg "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=$NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY" \
  --quiet || { echo "✗ Docker build failed."; exit 1; }

echo "✓ Docker image built successfully."
